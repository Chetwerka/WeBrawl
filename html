<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Brawl Stars WEB — Боевая арена</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            background: linear-gradient(145deg, #0a1f1e 0%, #06212a 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', 'Poppins', 'Fredoka One', 'Comic Neue', sans-serif;
            touch-action: manipulation;
        }

        .game-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            padding: 20px;
            border-radius: 56px;
            background: rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(3px);
            box-shadow: 0 25px 40px rgba(0, 0, 0, 0.5), inset 0 1px 2px rgba(255,255,255,0.1);
        }

        canvas {
            display: block;
            margin: 0 auto;
            border-radius: 32px;
            box-shadow: 0 12px 28px black, 0 0 0 4px #f7d44a, 0 0 0 8px #aa7e2c;
            cursor: crosshair;
            background: radial-gradient(circle at 30% 20%, #3b8b4c, #1d5436);
        }

        .info-panel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            gap: 40px;
            background: #1e2a2cee;
            padding: 12px 28px;
            border-radius: 60px;
            backdrop-filter: blur(4px);
            border: 1px solid #ffdd88;
            box-shadow: 0 6px 0 #0a2f2a;
        }

        .stats {
            display: flex;
            gap: 36px;
            background: #00000066;
            padding: 6px 24px;
            border-radius: 48px;
        }

        .stat {
            font-weight: bold;
            text-shadow: 0 2px 0 #1f3b2c;
            letter-spacing: 1px;
        }

        .stat span:first-child {
            color: #ffdd99;
            font-size: 1.2rem;
            margin-right: 8px;
        }

        .stat span:last-child {
            color: #fff5cf;
            font-size: 1.8rem;
            font-weight: 800;
            background: #00000077;
            padding: 0 12px;
            border-radius: 40px;
            line-height: 1.4;
        }

        .restart-btn {
            background: #f7b32b;
            border: none;
            font-family: inherit;
            font-weight: bold;
            font-size: 1.2rem;
            padding: 8px 24px;
            border-radius: 80px;
            color: #2c2b1f;
            cursor: pointer;
            transition: 0.1s linear;
            box-shadow: 0 5px 0 #9b5e1a;
            letter-spacing: 1px;
        }

        .restart-btn:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0 #9b5e1a;
        }

        .controls-tip {
            background: #000000aa;
            border-radius: 48px;
            padding: 6px 20px;
            font-size: 0.75rem;
            color: #ffe6b3;
            font-weight: 500;
            backdrop-filter: blur(4px);
            display: flex;
            gap: 24px;
        }

        .controls-tip span {
            background: #ffcf4a;
            color: #2a2412;
            padding: 2px 12px;
            border-radius: 30px;
            font-weight: bold;
            margin: 0 4px;
        }

        @keyframes pulse {
            0% { opacity: 0.7; text-shadow: 0 0 0px gold;}
            100% { opacity: 1; text-shadow: 0 0 6px #ffb347;}
        }

        .game-over-msg {
            font-size: 2rem;
            font-weight: bold;
            background: #cc2a2add;
            padding: 8px 24px;
            border-radius: 60px;
            animation: pulse 0.6s infinite alternate;
        }
    </style>
</head>
<body>
<div>
    <div class="game-container">
        <canvas id="gameCanvas" width="900" height="650"></canvas>
        <div class="info-panel">
            <div class="stats">
                <div class="stat"><span>❤️ ЗДОРОВЬЕ</span> <span id="hpValue">100</span></div>
                <div class="stat"><span>🏆 СЧЁТ</span> <span id="scoreValue">0</span></div>
                <div class="stat"><span>🤖 ВРАГИ</span> <span id="enemiesCount">0</span></div>
            </div>
            <button class="restart-btn" id="restartButton">⚡ НОВАЯ СХВАТКА ⚡</button>
        </div>
        <div class="controls-tip">
            <div> 🎮 <span>WASD</span> или <span>▲▼◀▶</span> — движение</div>
            <div> 🖱️ <span>ЛКМ</span> по арене — выстрел в цель</div>
            <div> ⚡ Перезарядка: 0.3 сек | Урон от врага -20HP</div>
        </div>
    </div>
</div>

<script>
    (function(){
        // ---------- CANVAS ----------
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        // ---------- ИГРОВЫЕ ПАРАМЕТРЫ ----------
        let gameRunning = true;
        let score = 0;
        
        // Игрок
        const player = {
            x: canvas.width/2,
            y: canvas.height/2,
            radius: 20,
            health: 100,
            maxHealth: 100,
            invincibleTimer: 0,      // >0 значит неуязвимость (секунды)
            speed: 5.2
        };
        
        // Динамические объекты
        let enemies = [];      // каждый {x, y, radius, hp, color, speed, angleToPlayer? просто движется к игроку}
        let projectiles = [];  // {x, y, radius, vx, vy, damage, life}
        
        // Параметры стрельбы
        let shootCooldown = 0;      // кадры до след. выстрела
        const SHOOT_DELAY_FRAMES = 18;  // ~0.3 сек при 60fps
        const PROJECTILE_RADIUS = 6;
        const PROJECTILE_DAMAGE = 100;   // враги умирают с 1 попадания
        const PROJECTILE_SPEED = 8.5;
        
        // Параметры врагов
        const ENEMY_BASE_RADIUS = 16;
        const ENEMY_BASE_SPEED = 1.7;
        const ENEMY_DAMAGE = 20;
        const INVINCIBLE_DURATION = 28;   // кадры неуязвимости (~0.47 сек)
        
        // Спавн врагов
        let spawnCounter = 0;
        const SPAWN_DELAY_FRAMES = 55;    // интервал спавна
        const MAX_ENEMIES = 12;
        
        // Управление (движение)
        const keys = {
            ArrowUp: false, ArrowDown: false, ArrowLeft: false, ArrowRight: false,
            w: false, s: false, a: false, d: false
        };
        
        // ---------- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ----------
        function clamp(value, min, max) {
            return Math.min(max, Math.max(min, value));
        }
        
        // проверка коллизии кругов
        function circlesCollide(x1,y1,r1, x2,y2,r2) {
            const dx = x1 - x2;
            const dy = y1 - y2;
            const dist = Math.hypot(dx, dy);
            return dist < r1 + r2;
        }
        
        // рестарт игры
        function restartGame() {
            gameRunning = true;
            score = 0;
            player.health = player.maxHealth;
            player.x = canvas.width/2;
            player.y = canvas.height/2;
            player.invincibleTimer = 0;
            enemies = [];
            projectiles = [];
            shootCooldown = 0;
            spawnCounter = 10;  // быстрый первый спавн
            updateUI();
        }
        
        // спавн врага в безопасной зоне (не на игроке)
        function spawnEnemy() {
            if(!gameRunning) return;
            if(enemies.length >= MAX_ENEMIES) return;
            
            let side = Math.floor(Math.random() * 4); // 0-3: края
            let x, y;
            const padding = 35;
            if(side === 0) { // верх
                x = Math.random() * (canvas.width - 2*padding) + padding;
                y = padding;
            } else if(side === 1) { // низ
                x = Math.random() * (canvas.width - 2*padding) + padding;
                y = canvas.height - padding;
            } else if(side === 2) { // лево
                x = padding;
                y = Math.random() * (canvas.height - 2*padding) + padding;
            } else { // право
                x = canvas.width - padding;
                y = Math.random() * (canvas.height - 2*padding) + padding;
            }
            
            // дополнительно: чтобы враг не спавнился прямо на игрока
            const dx = x - player.x;
            const dy = y - player.y;
            const distToPlayer = Math.hypot(dx, dy);
            if(distToPlayer < 70) {
                // смещаем немного
                const angle = Math.atan2(dy, dx);
                x = player.x + Math.cos(angle) * 100;
                y = player.y + Math.sin(angle) * 100;
                x = clamp(x, 25, canvas.width-25);
                y = clamp(y, 25, canvas.height-25);
            }
            
            enemies.push({
                x: x,
                y: y,
                radius: ENEMY_BASE_RADIUS,
                hp: 1,
                speed: ENEMY_BASE_SPEED + Math.random() * 0.6,
                color: `hsl(${Math.floor(Math.random() * 20 + 340)}, 70%, 55%)` // красноватые тона
            });
        }
        
        // выстрел в направлении мыши (координаты мыши относительно canvas)
        let mouseX = player.x, mouseY = player.y; // цель для прицела
        
        function shootTowards(targetX, targetY) {
            if(!gameRunning) return;
            if(shootCooldown > 0) return;
            
            // направление от игрока к цели
            let dx = targetX - player.x;
            let dy = targetY - player.y;
            const len = Math.hypot(dx, dy);
            if(len < 0.001) return;
            dx /= len;
            dy /= len;
            
            projectiles.push({
                x: player.x,
                y: player.y,
                radius: PROJECTILE_RADIUS,
                vx: dx * PROJECTILE_SPEED,
                vy: dy * PROJECTILE_SPEED,
                damage: PROJECTILE_DAMAGE,
                life: true
            });
            shootCooldown = SHOOT_DELAY_FRAMES;
            
            // маленькая вибрация/эффект (для отзывчивости)
        }
        
        // обновление UI (здоровье, счет, враги)
        function updateUI() {
            document.getElementById('hpValue').innerText = Math.max(0, player.health);
            document.getElementById('scoreValue').innerText = score;
            document.getElementById('enemiesCount').innerText = enemies.length;
        }
        
        // обработка получения урона игроком
        function damagePlayer(amount) {
            if(!gameRunning) return;
            if(player.invincibleTimer > 0) return;
            player.health -= amount;
            if(player.health <= 0) {
                player.health = 0;
                gameRunning = false;
                updateUI();
                return;
            }
            player.invincibleTimer = INVINCIBLE_DURATION;
            updateUI();
        }
        
        // обновление движения и логики
        function updateGame() {
            if(!gameRunning) return;
            
            // ---------- 1) Движение игрока (WASD + стрелки) ----------
            let moveX = 0, moveY = 0;
            if(keys.ArrowUp || keys.w) moveY -= 1;
            if(keys.ArrowDown || keys.s) moveY += 1;
            if(keys.ArrowLeft || keys.a) moveX -= 1;
            if(keys.ArrowRight || keys.d) moveX += 1;
            
            if(moveX !== 0 || moveY !== 0) {
                const len = Math.hypot(moveX, moveY);
                moveX = moveX / len;
                moveY = moveY / len;
            }
            
            let newX = player.x + moveX * player.speed;
            let newY = player.y + moveY * player.speed;
            // границы (с учетом радиуса)
            player.x = clamp(newX, player.radius + 2, canvas.width - player.radius - 2);
            player.y = clamp(newY, player.radius + 2, canvas.height - player.radius - 2);
            
            // таймер неуязвимости
            if(player.invincibleTimer > 0) {
                player.invincibleTimer--;
            }
            
            // перезарядка выстрела
            if(shootCooldown > 0) shootCooldown--;
            
            // ---------- 2) Движение врагов к игроку ----------
            for(let i = 0; i < enemies.length; i++) {
                const e = enemies[i];
                const dx = player.x - e.x;
                const dy = player.y - e.y;
                const dist = Math.hypot(dx, dy);
                if(dist > 0.01) {
                    const move = e.speed;
                    const stepX = (dx / dist) * move;
                    const stepY = (dy / dist) * move;
                    e.x += stepX;
                    e.y += stepY;
                }
                // границы для врагов (чтобы не выходили)
                e.x = clamp(e.x, e.radius + 2, canvas.width - e.radius - 2);
                e.y = clamp(e.y, e.radius + 2, canvas.height - e.radius - 2);
            }
            
            // ---------- 3) Столкновения враг-игрок (наносит урон и враг исчезает) ----------
            for(let i = enemies.length-1; i >= 0; i--) {
                const e = enemies[i];
                if(circlesCollide(player.x, player.y, player.radius, e.x, e.y, e.radius)) {
                    // наносим урон игроку
                    damagePlayer(ENEMY_DAMAGE);
                    // враг умирает от удара (как самоуничтожение, чтобы избежать спама)
                    enemies.splice(i,1);
                    if(player.health <= 0) {
                        gameRunning = false;
                        updateUI();
                        return;
                    }
                }
            }
            
            // ---------- 4) Снаряды и их коллизия с врагами ----------
            for(let i = projectiles.length-1; i >= 0; i--) {
                const p = projectiles[i];
                // движение
                p.x += p.vx;
                p.y += p.vy;
                // границы - удалить если за пределами
                if(p.x + p.radius < 0 || p.x - p.radius > canvas.width || p.y + p.radius < 0 || p.y - p.radius > canvas.height) {
                    projectiles.splice(i,1);
                    continue;
                }
                
                let hit = false;
                for(let j = enemies.length-1; j >= 0; j--) {
                    const e = enemies[j];
                    if(circlesCollide(p.x, p.y, p.radius, e.x, e.y, e.radius)) {
                        // попадание по врагу
                        enemies.splice(j,1);
                        hit = true;
                        score++;
                        updateUI();
                        break;
                    }
                }
                if(hit) {
                    projectiles.splice(i,1);
                }
            }
            
            // ---------- 5) Спавн врагов (таймер) ----------
            if(gameRunning && enemies.length < MAX_ENEMIES) {
                if(spawnCounter <= 0) {
                    spawnEnemy();
                    spawnCounter = SPAWN_DELAY_FRAMES;
                    // дополнительный спавн иногда по два для сложности? но лимит 12
                    if(enemies.length < MAX_ENEMIES && Math.random() < 0.25 && gameRunning) {
                        spawnEnemy();
                    }
                } else {
                    spawnCounter--;
                }
            } else if(spawnCounter > 0) {
                spawnCounter--;
            }
            
            // если игра закончилась во время обновления, не спавним больше
            if(player.health <= 0) {
                gameRunning = false;
            }
            
            updateUI(); // обновляем кол-во врагов и счёт
        }
        
        // ---------- ОТРИСОВКА ВСЕГО (стиль Brawl Stars) ----------
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // --- Декоративный фон (травка, узоры) ---
            ctx.save();
            // сетка арены
            ctx.strokeStyle = "#a5d6a5";
            ctx.lineWidth = 1.5;
            for(let i = 0; i < canvas.width; i+= 60){
                ctx.beginPath();
                ctx.moveTo(i,0);
                ctx.lineTo(i,canvas.height);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(0,i);
                ctx.lineTo(canvas.width,i);
                ctx.stroke();
            }
            // полупрозрачные блики
            ctx.fillStyle = "#d4f1b980";
            for(let i = 0; i < 12; i++) {
                ctx.beginPath();
                ctx.arc(120+ i*70, 80+ (i%3)*90, 28, 0, Math.PI*2);
                ctx.fill();
            }
            
            // ---- Снаряды (энергетические шары) ----
            for(const p of projectiles) {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius-1, 0, Math.PI*2);
                ctx.fillStyle = "#FFE484";
                ctx.fill();
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius-2, 0, Math.PI*2);
                ctx.fillStyle = "#FFB347";
                ctx.fill();
                ctx.shadowBlur = 12;
                ctx.shadowColor = "#f9a825";
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius-3, 0, Math.PI*2);
                ctx.fillStyle = "white";
                ctx.fill();
                ctx.shadowBlur = 0;
            }
            
            // ---- Враги (злобные бандиты) ----
            for(const e of enemies) {
                // градиент
                const grad = ctx.createRadialGradient(e.x-5, e.y-5, 3, e.x, e.y, e.radius);
                grad.addColorStop(0, "#E34D4D");
                grad.addColorStop(1, "#A61C1C");
                ctx.beginPath();
                ctx.arc(e.x, e.y, e.radius, 0, Math.PI*2);
                ctx.fillStyle = grad;
                ctx.fill();
                ctx.strokeStyle = "#5a1e1e";
                ctx.lineWidth = 2;
                ctx.stroke();
                // злые глаза
                ctx.fillStyle = "white";
                ctx.beginPath();
                ctx.arc(e.x-6, e.y-4, 4, 0, Math.PI*2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(e.x+6, e.y-4, 4, 0, Math.PI*2);
                ctx.fill();
                ctx.fillStyle = "#2C0F0F";
                ctx.beginPath();
                ctx.arc(e.x-6.5, e.y-5, 1.8, 0, Math.PI*2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(e.x+5.5, e.y-5, 1.8, 0, Math.PI*2);
                ctx.fill();
                // брови
                ctx.beginPath();
                ctx.strokeStyle = "#3b0d0d";
                ctx.lineWidth = 3;
                ctx.moveTo(e.x-10, e.y-9);
                ctx.lineTo(e.x-4, e.y-7);
                ctx.moveTo(e.x+10, e.y-9);
                ctx.lineTo(e.x+4, e.y-7);
                ctx.stroke();
                // рожки
                ctx.beginPath();
                ctx.moveTo(e.x-12, e.y-14);
                ctx.lineTo(e.x-4, e.y-12);
                ctx.lineTo(e.x-8, e.y-19);
                ctx.fillStyle = "#6B2E2E";
                ctx.fill();
                ctx.beginPath();
                ctx.moveTo(e.x+12, e.y-14);
                ctx.lineTo(e.x+4, e.y-12);
                ctx.lineTo(e.x+8, e.y-19);
                ctx.fill();
            }
            
            // ---- Игрок (Brawler) яркий и крутой ----
            const p = player;
            // свечение
            ctx.shadowBlur = 12;
            ctx.shadowColor = "#fbc02d";
            const gradPlayer = ctx.createLinearGradient(p.x-8, p.y-8, p.x+8, p.y+12);
            gradPlayer.addColorStop(0, "#FFD966");
            gradPlayer.addColorStop(1, "#E6A017");
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI*2);
            ctx.fillStyle = gradPlayer;
            ctx.fill();
            ctx.strokeStyle = "#FFB347";
            ctx.lineWidth = 2.5;
            ctx.stroke();
            // маска / звездный боец
            ctx.fillStyle = "#34200c";
            ctx.beginPath();
            ctx.ellipse(p.x-6, p.y-2, 4, 5, 0, 0, Math.PI*2);
            ctx.fill();
            ctx.beginPath();
            ctx.ellipse(p.x+6, p.y-2, 4, 5, 0, 0, Math.PI*2);
            ctx.fill();
            ctx.fillStyle = "white";
            ctx.beginPath();
            ctx.arc(p.x-6, p.y-4, 2, 0, Math.PI*2);
            ctx.fill();
            ctx.beginPath();
            ctx.arc(p.x+6, p.y-4, 2, 0, Math.PI*2);
            ctx.fill();
            ctx.fillStyle = "#222";
            ctx.beginPath();
            ctx.arc(p.x-6.5, p.y-5, 0.9, 0, Math.PI*2);
            ctx.fill();
            ctx.beginPath();
            ctx.arc(p.x+5.5, p.y-5, 0.9, 0, Math.PI*2);
            ctx.fill();
            // улыбка
            ctx.beginPath();
            ctx.arc(p.x, p.y+4, 8, 0.05, Math.PI - 0.05);
            ctx.strokeStyle = "#4a2a0a";
            ctx.lineWidth = 2;
            ctx.stroke();
            // повязка / бандана
            ctx.beginPath();
            ctx.moveTo(p.x-14, p.y-12);
            ctx.lineTo(p.x, p.y-18);
            ctx.lineTo(p.x+14, p.y-12);
            ctx.fillStyle = "#E63946";
            ctx.fill();
            ctx.fillStyle = "#FFF1B5";
            ctx.font = `bold ${p.radius-4}px "Segoe UI"`;
            ctx.shadowBlur = 4;
            ctx.fillText("⚡", p.x-10, p.y-13);
            ctx.shadowBlur = 0;
            
            // индикатор неуязвимости (щит)
            if(player.invincibleTimer > 0) {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius+3, 0, Math.PI*2);
                ctx.strokeStyle = "#FFF7B0";
                ctx.lineWidth = 3;
                ctx.setLineDash([6, 8]);
                ctx.stroke();
                ctx.setLineDash([]);
            }
            
            // полоска здоровья над игроком
            const hpPercent = player.health / player.maxHealth;
            const barWidth = 50;
            const barX = p.x - barWidth/2;
            const barY = p.y - p.radius - 8;
            ctx.fillStyle = "#631a1a";
            ctx.fillRect(barX, barY, barWidth, 8);
            ctx.fillStyle = "#ff5e5e";
            ctx.fillRect(barX, barY, barWidth * hpPercent, 8);
            ctx.fillStyle = "#ffd966";
            ctx.font = "bold 12monospace";
            ctx.shadowBlur = 0;
            ctx.fillText(`${player.health}`, p.x-12, barY-2);
            
            // ---- Прицел (направление мыши) ----
            if(gameRunning) {
                ctx.beginPath();
                ctx.arc(mouseX, mouseY, 9, 0, Math.PI*2);
                ctx.strokeStyle = "#ffea9e";
                ctx.lineWidth = 2;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(mouseX-16, mouseY);
                ctx.lineTo(mouseX+16, mouseY);
                ctx.moveTo(mouseX, mouseY-16);
                ctx.lineTo(mouseX, mouseY+16);
                ctx.stroke();
                ctx.beginPath();
                ctx.arc(mouseX, mouseY, 4, 0, Math.PI*2);
                ctx.fillStyle = "#ffffbbaa";
                ctx.fill();
            }
            
            // Game Over overlay
            if(!gameRunning && player.health <= 0) {
                ctx.font = "bold 44 'Fredoka One'";
                ctx.shadowBlur = 0;
                ctx.fillStyle = "#FFD966";
                ctx.shadowColor = "black";
                ctx.fillText("GAME OVER", canvas.width/2-130, canvas.height/2-40);
                ctx.font = "24px 'Segoe UI'";
                ctx.fillStyle = "#FFF2B5";
                ctx.fillText("нажми «НОВАЯ СХВАТКА»", canvas.width/2-150, canvas.height/2+30);
                ctx.fillStyle = "#ffbc6e";
                ctx.font = "18px monospace";
                ctx.fillText("враги раздавят, но ты сражался как легенда", canvas.width/2-190, canvas.height/2+85);
            }
            
            // маленький счетчик врагов на арене
            ctx.font = "bold 20monospace";
            ctx.fillStyle = "#FFF6CF";
            ctx.shadowBlur = 2;
            ctx.fillText("⚔️ " + enemies.length, 20, 50);
            ctx.restore();
        }
        
        // ---------- ОБРАБОТЧИКИ УПРАВЛЕНИЯ ----------
        function handleKeyDown(e) {
            const key = e.key;
            if(keys.hasOwnProperty(key)) {
                keys[key] = true;
                e.preventDefault();
            }
            // блокировка прокрутки стрелками
            if (key === "ArrowUp" || key === "ArrowDown" || key === "ArrowLeft" || key === "ArrowRight") {
                e.preventDefault();
            }
        }
        
        function handleKeyUp(e) {
            const key = e.key;
            if(keys.hasOwnProperty(key)) {
                keys[key] = false;
                e.preventDefault();
            }
        }
        
        function getMousePos(e) {
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            let mouseCanvasX = (e.clientX - rect.left) * scaleX;
            let mouseCanvasY = (e.clientY - rect.top) * scaleY;
            mouseCanvasX = clamp(mouseCanvasX, 0, canvas.width);
            mouseCanvasY = clamp(mouseCanvasY, 0, canvas.height);
            return { mx: mouseCanvasX, my: mouseCanvasY };
        }
        
        function onMouseMove(e) {
            const { mx, my } = getMousePos(e);
            mouseX = mx;
            mouseY = my;
        }
        
        function onMouseShoot(e) {
            if(!gameRunning) return;
            const { mx, my } = getMousePos(e);
            shootTowards(mx, my);
            e.preventDefault();
        }
        
        // запрет контекстного меню на канвасе
        canvas.addEventListener('contextmenu', (e) => e.preventDefault());
        canvas.addEventListener('mousemove', onMouseMove);
        canvas.addEventListener('mousedown', onMouseShoot);
        window.addEventListener('keydown', handleKeyDown);
        window.addEventListener('keyup', handleKeyUp);
        
        // кнопка рестарта
        const restartBtn = document.getElementById('restartButton');
        restartBtn.addEventListener('click', () => {
            restartGame();
            gameRunning = true;
            if(player.health <= 0) player.health = player.maxHealth;
            player.invincibleTimer = 0;
            enemies = [];
            projectiles = [];
            shootCooldown = 0;
            spawnCounter = 5;
            score = 0;
            updateUI();
        });
        
        // стартовый спавн пары врагов
        function initSpawn() {
            for(let i=0; i<3; i++) spawnEnemy();
            spawnCounter = 30;
        }
        
        // АНИМАЦИОННЫЙ ЦИКЛ
        function gameLoop() {
            updateGame();
            draw();
            requestAnimationFrame(gameLoop);
        }
        
        restartGame();    // начальное состояние
        initSpawn();
        updateUI();
        gameLoop();
    })();
</script>
</body>
</html>
